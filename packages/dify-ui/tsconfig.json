{
  "extends": "@dify/tsconfig/react.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src", "tests", "vite.config.ts"]
}
