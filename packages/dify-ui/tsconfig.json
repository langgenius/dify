{
  "extends": "@dify/tsconfig/react.json",
  "compilerOptions": {
    "types": ["vite-plus/test/globals", "vite-plus/test/matchers"]
  },
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
