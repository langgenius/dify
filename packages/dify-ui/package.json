{
  "name": "@langgenius/dify-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./styles.css": "./src/styles/styles.css",
    "./tailwind-preset": {
      "import": "./src/tailwind-preset.ts",
      "types": "./src/tailwind-preset.ts"
    },
