{
  "extends": "@dify/tsconfig/react.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["../../web/*", "./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__tests__",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx"
  ]
}
