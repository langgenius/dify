#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONTRIBUTING_FILE="$ROOT_DIR/CONTRIBUTING.md"
PR_TEMPLATE_FILE="$ROOT_DIR/.github/pull_request_template.md"

if grep -n "🤖🤖🤖" "$CONTRIBUTING_FILE" "$PR_TEMPLATE_FILE" >/dev/null; then
  echo "Deprecated robot emoji attribution guidance is still present."
  exit 1
fi

grep -n "From <Tool Name>" "$CONTRIBUTING_FILE" >/dev/null
grep -n "From <Tool Name>" "$PR_TEMPLATE_FILE" >/dev/null

echo "Agent PR guidance is consistent."
