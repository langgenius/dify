# E2E test environment template — copy to .env.e2e and fill in the values.
# .env.e2e is git-ignored; this file is safe to commit.
#
# ── Edition selector ────────────────────────────────────────────────────────
# Set to "ee" for Enterprise Edition; leave empty or "ce" for Community Edition.
# EE-only test cases are tagged [EE] and are automatically skipped in CE mode.
DIFY_E2E_EDITION=ce

# ══════════════════════════════════════════════════════════════════════════════
# Community Edition (CE) — minimum required (3 vars only)
#   global-setup will:
#     1. Register a new account with EMAIL/PASSWORD
#     2. Mint an auth token via the device flow
#     3. Import all DSL fixtures into the single workspace
#     4. Publish apps and set access_mode → public
# ══════════════════════════════════════════════════════════════════════════════
DIFY_E2E_HOST=
DIFY_E2E_EMAIL=
DIFY_E2E_PASSWORD=

# ══════════════════════════════════════════════════════════════════════════════
# Enterprise Edition (EE) — required when DIFY_E2E_EDITION=ee
#   global-setup will:
#     1. Use ENTERPRISE_API to create a member account
#     2. Create two workspaces for the member via the enterprise admin API
#     3. Import DSL fixtures into both workspaces
#     4. Publish apps and set access_mode → public via the enterprise API
# ══════════════════════════════════════════════════════════════════════════════
# Enterprise admin API base URL  (e.g. https://<enterprise-api-host>/inner/api)
# DIFY_E2E_ENTERPRISE_API_URL=
# Enterprise admin API secret key
# DIFY_E2E_ENTERPRISE_API_SECRET_KEY=
# Console URL for EE (may differ from the enterprise API host)
# DIFY_E2E_CONSOLE_URL=

# ── Optional overrides ─────────────────────────────────────────────────────
# Rarely needed. global-setup resolves these dynamically.
# Set them only to pin specific values or skip the device-flow mint.

# Pre-minted primary token — skips device-flow mint in global-setup
# DIFY_E2E_TOKEN=

# External SSO bearer token (dfoe_ prefix) — enables SSO test cases
# DIFY_E2E_SSO_TOKEN=

# Override workspace IDs (default: first/second "auto" workspace found)
# DIFY_E2E_WORKSPACE_ID=
# DIFY_E2E_WORKSPACE_NAME=
# DIFY_E2E_WS2_ID=

# Override app IDs (default: provisioned from fixture DSL files)
# DIFY_E2E_CHAT_APP_ID=
# DIFY_E2E_WORKFLOW_APP_ID=
# DIFY_E2E_FILE_APP_ID=
# DIFY_E2E_FILE_CHAT_APP_ID=
# DIFY_E2E_HITL_APP_ID=
# DIFY_E2E_HITL_EXTERNAL_APP_ID=
# DIFY_E2E_HITL_SINGLE_ACTION_APP_ID=
# DIFY_E2E_HITL_MULTI_NODE_APP_ID=
# DIFY_E2E_WS2_APP_ID=
