# E2E test environment template — copy to .env.e2e and fill in the values.
# .env.e2e is git-ignored; this file is safe to commit.
#
# ── Edition selector ────────────────────────────────────────────────────────
# "ce" (default) = Community Edition   "ee" = Enterprise Edition
# EE-only test cases ([EE] tag) are automatically skipped in CE mode.
DIFY_E2E_EDITION=ce

# ── Required (both editions) ────────────────────────────────────────────────
DIFY_E2E_HOST=
DIFY_E2E_EMAIL=
DIFY_E2E_PASSWORD=

# ── EE notes ────────────────────────────────────────────────────────────────
# When DIFY_E2E_EDITION=ee the operator must pre-create two workspaces for the
# test account BEFORE running the suite:
#   primary   → workspace name: "auto_test0"
#   secondary → workspace name: "auto_test1"
# global-setup discovers them by exact name, imports DSL fixtures into both,
# publishes apps, and sets access_mode → public automatically.

# ── Optional overrides ───────────────────────────────────────────────────────
# Console URL when different from DIFY_E2E_HOST (e.g. EE console proxy)
# DIFY_E2E_CONSOLE_URL=

# Pre-minted primary token — skips device-flow mint in global-setup
# DIFY_E2E_TOKEN=

# External SSO bearer token (dfoe_ prefix) — enables SSO test cases
# DIFY_E2E_SSO_TOKEN=

# Override workspace IDs (default: discovered by global-setup)
# DIFY_E2E_WORKSPACE_ID=
# DIFY_E2E_WORKSPACE_NAME=
# DIFY_E2E_WS2_ID=

# Override app IDs (default: provisioned from fixture DSL files)
# DIFY_E2E_CHAT_APP_ID=
# DIFY_E2E_WORKFLOW_APP_ID=
# DIFY_E2E_FILE_APP_ID=
# DIFY_E2E_FILE_CHAT_APP_ID=
# DIFY_E2E_HITL_APP_ID=
# DIFY_E2E_HITL_EXTERNAL_APP_ID=
# DIFY_E2E_HITL_SINGLE_ACTION_APP_ID=
# DIFY_E2E_HITL_MULTI_NODE_APP_ID=
# DIFY_E2E_WS2_APP_ID=
