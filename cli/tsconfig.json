{
  "extends": "@dify/tsconfig/node.json",
  "compilerOptions": {
    "rootDir": "src",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@test/*": [
        "./test/*"
      ]
    },
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "test", "node_modules", "**/*.test.ts"]
}
