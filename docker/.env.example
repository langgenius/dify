# ------------------------------
# API 服務與 Worker 的環境變數
# ------------------------------

# ------------------------------
# 通用變數
# ------------------------------

# Console API 後端 URL，
# 用於拼接授權回呼網址。
# 若為空，則使用相同網域。
# 範例：https://api.console.dify.ai
CONSOLE_API_URL=

# Console 前端 URL，
# 用於拼接部分前端網址及 CORS 設定。
# 若為空，則使用相同網域。
# 範例：https://console.dify.ai
CONSOLE_WEB_URL=

# Service API URL，
# 用於在前端顯示 Service API 基礎 URL。
# 若為空，則使用相同網域。
# 範例：https://api.dify.ai
SERVICE_API_URL=

# Trigger 外部 URL
# 用於在前端顯示 Trigger 端點 API 基礎 URL。
# 範例：https://api.dify.ai
TRIGGER_URL=http://localhost

# WebApp API 後端 URL，
# 用於宣告前端 API 的後端 URL。
# 若為空，則使用相同網域。
# 範例：https://api.app.dify.ai
APP_API_URL=

# WebApp URL，
# 用於在前端顯示 WebApp API 基礎 URL。
# 若為空，則使用相同網域。
# 範例：https://app.dify.ai
APP_WEB_URL=

# 檔案預覽或下載 URL 前綴。
# 用於在前端顯示檔案預覽或下載 URL，或作為多模態輸入；
# URL 已簽章並具有過期時間。
# 檔案處理外掛程式需要設定 FILES_URL。
#   - 若使用 https://example.com，請設定 FILES_URL=https://example.com
#   - 若使用 http://example.com，請設定 FILES_URL=http://example.com
#   建議：使用專用網域（例如 https://upload.example.com）。
#   或者使用 http://<your-ip>:5001 或 http://api:5001，
#   確保埠 5001 可從外部存取（請參閱 docker-compose.yaml）。
FILES_URL=

# INTERNAL_FILES_URL 用於 Docker 網路內外掛程式 Daemon 的通訊。
# 請設定為 Docker 內部服務 URL，以確保外掛程式正確存取檔案。
# 範例：INTERNAL_FILES_URL=http://api:5001
INTERNAL_FILES_URL=

# 確保 UTF-8 編碼
LANG=C.UTF-8
LC_ALL=C.UTF-8
PYTHONIOENCODING=utf-8

# 設定 UV 快取目錄，以避免家目錄不存在時的權限問題
UV_CACHE_DIR=/tmp/.uv-cache

# ------------------------------
# 伺服器設定
# ------------------------------

# 應用程式的日誌等級。
# 支援的值為 `DEBUG`、`INFO`、`WARNING`、`ERROR`、`CRITICAL`
LOG_LEVEL=INFO
# 日誌輸出格式：text 或 json
LOG_OUTPUT_FORMAT=text
# 日誌檔案路徑
LOG_FILE=/app/logs/server.log
# 日誌檔案大小上限，單位為 MB
LOG_FILE_MAX_SIZE=20
# 日誌檔案備份數量上限
LOG_FILE_BACKUP_COUNT=5
# 日誌日期格式
LOG_DATEFORMAT=%Y-%m-%d %H:%M:%S
# 日誌時區
LOG_TZ=UTC

# 除錯模式，預設為 false。
# 建議在本地開發時開啟此設定，
# 以避免 monkey patch 造成的問題。
DEBUG=false

# Flask 除錯模式，開啟後介面可輸出追蹤資訊，
# 方便除錯。
FLASK_DEBUG=false

# 啟用請求日誌，將記錄請求和回應資訊。
# 且日誌等級為 DEBUG
ENABLE_REQUEST_LOGGING=False

# 用於安全簽章 Session Cookie 的密鑰
# 以及加密資料庫中的敏感資訊。
# 可使用 `openssl rand -base64 42` 產生強密鑰。
SECRET_KEY=sk-9f73s3ljTXVcMT3Blb3ljTqtsKiGHXVcMT3BlbkFJLK7U

# 管理員使用者初始化密碼。
# 若未設定，建立初始管理員帳號時不會提示輸入密碼。
# 建立初始管理員帳號時。
# 密碼長度不得超過 30 個字元。
INIT_PASSWORD=

# 部署環境。
# 支援的值為 `PRODUCTION`、`TESTING`，預設為 `PRODUCTION`。
# 測試環境。前端頁面將顯示明顯的顏色標籤，
# 以標示此為測試環境。
DEPLOY_ENV=PRODUCTION

# 是否啟用版本檢查策略。
# 若設為空，將呼叫 https://updates.dify.ai 進行版本檢查。
CHECK_UPDATE_URL=https://updates.dify.ai

# 用於變更 OpenAI 基礎地址，預設為 https://api.openai.com/v1。
# 當 OpenAI 在中國無法存取時，可替換為國內鏡像地址，
# 或當本地模型提供 OpenAI 相容 API 時，也可替換。
OPENAI_API_BASE=https://api.openai.com/v1

# 啟用後，將在應用程式啟動前執行資料庫遷移，
# 並在遷移完成後啟動應用程式。
MIGRATION_ENABLED=true

# 檔案存取時間，指定檔案可被存取的時間間隔（秒）。
# 預設值為 300 秒。
FILES_ACCESS_TIMEOUT=300

# Access token 過期時間（分鐘）
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token 過期時間（天）
REFRESH_TOKEN_EXPIRE_DAYS=30

# 應用程式的預設活躍請求數，0 表示無限制，須為非負整數。
APP_DEFAULT_ACTIVE_REQUESTS=0
# 應用程式的最大活躍請求數，0 表示無限制，須為非負整數。
APP_MAX_ACTIVE_REQUESTS=0
APP_MAX_EXECUTION_TIME=1200

# ------------------------------
# 容器啟動相關設定
# 僅在使用 Docker 映像或 docker-compose 啟動時有效。
# ------------------------------

# API 服務綁定地址，預設 0.0.0.0，即所有地址皆可存取。
DIFY_BIND_ADDRESS=0.0.0.0

# API 服務綁定埠號，預設 5001。
DIFY_PORT=5001

# API 伺服器 Worker 數量。
# 公式：同步模式為 CPU 核心數 × 2 + 1，Gevent 模式為 1
# 參考：https://docs.gunicorn.org/en/stable/design.html#how-many-workers
SERVER_WORKER_AMOUNT=1

# 預設為 gevent。若使用 Windows，可切換為 sync 或 solo。
#
# 警告：變更此參數需停用以下模組的 patching：
# psycopg2 及 gRPC（請參閱 `gunicorn.conf.py` 和 `celery_entrypoint.py`）。
# 修改此參數也可能降低吞吐量。
#
# 強烈不建議修改此參數。
SERVER_WORKER_CLASS=gevent

# Worker 預設連線數，預設值為 10。
SERVER_WORKER_CONNECTIONS=10

# 與 SERVER_WORKER_CLASS 類似。
# 若使用 Windows，可切換為 sync 或 solo。
#
# 警告：變更此參數需停用以下模組的 patching：
# psycopg2 及 gRPC（請參閱 `gunicorn_conf.py` 和 `celery_entrypoint.py`）。
# 修改此參數也可能降低吞吐量。
#
# 強烈不建議修改此參數。
CELERY_WORKER_CLASS=

# 請求處理逾時時間，預設為 200，
# 建議設為 360 以支援較長的 SSE 連線時間。
GUNICORN_TIMEOUT=360

# Celery Worker 數量，預設為 1，可依需求調整。
CELERY_WORKER_AMOUNT=

# 是否啟用 Celery Worker 自動擴縮容的旗標。
#
# 自動擴縮容適用於 CPU 密集型任務，可動態
# 根據工作負載分配和釋放資源。
#
# 啟用自動擴縮容時，可指定 Worker 的最大和最小數量，
# 自動擴縮容演算法將在指定範圍內動態調整
# Worker 數量。
#
# 預設為 false（即停用自動擴縮容）。
#
# 範例：
# CELERY_AUTO_SCALE=true
CELERY_AUTO_SCALE=false

# 自動擴縮容時 Celery Worker 的最大數量。
# 此設定為選填，僅在啟用自動擴縮容時使用。
# 預設未設定。
CELERY_MAX_WORKERS=

# 自動擴縮容時 Celery Worker 的最小數量。
# 此設定為選填，僅在啟用自動擴縮容時使用。
# 預設未設定。
CELERY_MIN_WORKERS=

# API 工具設定
API_TOOL_DEFAULT_CONNECT_TIMEOUT=10
API_TOOL_DEFAULT_READ_TIMEOUT=60

# -------------------------------
# 資料來源設定
# --------------------------------
ENABLE_WEBSITE_JINAREADER=true
ENABLE_WEBSITE_FIRECRAWL=true
ENABLE_WEBSITE_WATERCRAWL=true

# 在前端啟用單一美元符號（$...$）的行內 LaTeX 渲染
# 基於安全考量，預設為 false，以避免與一般文字衝突
NEXT_PUBLIC_ENABLE_SINGLE_DOLLAR_LATEX=false

# ------------------------------
# 資料庫設定
# 資料庫使用 PostgreSQL 或 MySQL，亦支援 OceanBase 和 seekdb，請使用 public schema。
# 與下方資料庫服務的設定保持一致。
# 可依需求調整資料庫設定。
# ------------------------------

# 資料庫類型，支援 `postgresql`、`mysql`、`oceanbase`、`seekdb`
DB_TYPE=postgresql
# MySQL 目前僅支援 `root` 使用者
DB_USERNAME=dify
DB_PASSWORD=o*Xx3aPQ
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=dify

# 資料庫連線池大小。
# 預設 30 個連線，可視需求適當增加。
SQLALCHEMY_POOL_SIZE=30
# 預設 10 個連線，允許超出連線池大小的暫時溢出。
SQLALCHEMY_MAX_OVERFLOW=10
# 資料庫連線池回收時間，預設 3600 秒。
SQLALCHEMY_POOL_RECYCLE=3600
# 是否列印 SQL，預設為 false。
SQLALCHEMY_ECHO=false
# 若為 True，每次取出連線時將測試其存活狀態
SQLALCHEMY_POOL_PRE_PING=false
# 是否啟用後進先出模式，false 則使用預設的 FIFO 佇列
SQLALCHEMY_POOL_USE_LIFO=false
# 從連線池等待連線的秒數，超過則拋出逾時錯誤。
# 預設為 30
SQLALCHEMY_POOL_TIMEOUT=30

# 資料庫最大連線數
# 預設為 100
#
# 參考：https://www.postgresql.org/docs/current/runtime-config-connection.html#GUC-MAX-CONNECTIONS
POSTGRES_MAX_CONNECTIONS=100

# 設定 PostgreSQL 共用緩衝區使用的共用記憶體大小。
# 預設為 128MB
# 建議值：可用記憶體的 25%
# 參考：https://www.postgresql.org/docs/current/runtime-config-resource.html#GUC-SHARED-BUFFERS
POSTGRES_SHARED_BUFFERS=128MB

# 設定每個資料庫 Worker 工作空間使用的記憶體大小。
# 預設為 4MB
#
# 參考：https://www.postgresql.org/docs/current/runtime-config-resource.html#GUC-WORK-MEM
POSTGRES_WORK_MEM=4MB

# 設定保留給維護作業的記憶體大小。
# 預設為 64MB
#
# 參考：https://www.postgresql.org/docs/current/runtime-config-resource.html#GUC-MAINTENANCE-WORK-MEM
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# 設定規劃器對有效快取大小的假設。
# 預設為 4096MB
#
# 參考：https://www.postgresql.org/docs/current/runtime-config-query.html#GUC-EFFECTIVE-CACHE-SIZE
POSTGRES_EFFECTIVE_CACHE_SIZE=4096MB

# 設定任何陳述式執行前被終止的最長允許時間。
# 預設為 0（不逾時）。
#
# 參考：https://www.postgresql.org/docs/current/runtime-config-client.html#GUC-STATEMENT-TIMEOUT
# 值為 0 表示伺服器不會對陳述式設定逾時。
POSTGRES_STATEMENT_TIMEOUT=0

# 設定事務中閒置 Session 被終止前的最長允許時間。
# 預設為 0（不逾時）。
#
# 參考：https://www.postgresql.org/docs/current/runtime-config-client.html#GUC-IDLE-IN-TRANSACTION-SESSION-TIMEOUT
# 值為 0 表示伺服器不會終止閒置的 Session。
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=0

# MySQL 效能設定
# MySQL 最大連線數
#
# 預設為 1000
MYSQL_MAX_CONNECTIONS=1000

# InnoDB 緩衝池大小
# 預設為 512M
# 建議值：MySQL 專用伺服器可用記憶體的 70-80%
# 參考：https://dev.mysql.com/doc/refman/8.0/en/innodb-parameters.html#sysvar_innodb_buffer_pool_size
MYSQL_INNODB_BUFFER_POOL_SIZE=512M

# InnoDB 日誌檔案大小
# 預設為 128M
# 參考：https://dev.mysql.com/doc/refman/8.0/en/innodb-parameters.html#sysvar_innodb_log_file_size
MYSQL_INNODB_LOG_FILE_SIZE=128M

# InnoDB 在事務提交時刷新日誌
# 預設為 2（刷新至 OS 快取，每秒同步）
# 選項：0（不刷新）、1（刷新並同步）、2（刷新至 OS 快取）
# 參考：https://dev.mysql.com/doc/refman/8.0/en/innodb-parameters.html#sysvar_innodb_flush_log_at_trx_commit
MYSQL_INNODB_FLUSH_LOG_AT_TRX_COMMIT=2

# ------------------------------
# Redis 設定
# 此 Redis 設定用於快取及對話期間的 Pub/Sub。
# ------------------------------

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=%@z%dVBRS2f8io
REDIS_USE_SSL=false
# Redis 的 SSL 設定（當 REDIS_USE_SSL=true 時）
REDIS_SSL_CERT_REQS=CERT_NONE
# 選項：CERT_NONE、CERT_OPTIONAL、CERT_REQUIRED
REDIS_SSL_CA_CERTS=
# SSL 驗證用 CA 憑證檔案路徑
REDIS_SSL_CERTFILE=
# SSL 驗證用用戶端憑證檔案路徑
REDIS_SSL_KEYFILE=
# SSL 驗證用用戶端私鑰檔案路徑
REDIS_DB=0
# 選填：限制 API/Worker 使用的 Redis 總連線數（未設定則使用預設值）
# 需與設定中 API 的 REDIS_MAX_CONNECTIONS 一致
REDIS_MAX_CONNECTIONS=

# 是否使用 Redis Sentinel 模式。
# 若設為 true，應用程式將透過 Sentinel 自動探索並連線至主節點。
REDIS_USE_SENTINEL=false

# Redis Sentinel 節點清單。啟用 Sentinel 模式時，至少需提供一個 Sentinel IP 和埠。
# 格式：`<sentinel1_ip>:<sentinel1_port>,<sentinel2_ip>:<sentinel2_port>,<sentinel3_ip>:<sentinel3_port>`
REDIS_SENTINELS=
REDIS_SENTINEL_SERVICE_NAME=
REDIS_SENTINEL_USERNAME=
REDIS_SENTINEL_PASSWORD=
REDIS_SENTINEL_SOCKET_TIMEOUT=0.1

# Redis Cluster 節點清單。啟用 Cluster 模式時，至少需提供一個 Cluster IP 和埠。
# 格式：`<Cluster1_ip>:<Cluster1_port>,<Cluster2_ip>:<Cluster2_port>,<Cluster3_ip>:<Cluster3_port>`
REDIS_USE_CLUSTERS=false
REDIS_CLUSTERS=
REDIS_CLUSTERS_PASSWORD=

# ------------------------------
# Celery 設定
# ------------------------------

# 使用獨立 Redis 作為 broker，Celery 使用 Redis db 1。（redis_username 通常預設為空）
# 格式：`redis://<redis_username>:<redis_password>@<redis_host>:<redis_port>/<redis_database>`。
# 範例：redis://:difyai123456@redis:6379/1
# 若使用 Redis Sentinel，格式為：`sentinel://<redis_username>:<redis_password>@<sentinel_host1>:<sentinel_port>/<redis_database>`
# 如需高可用性，可用分號分隔多個 Sentinel 節點，如下範例：
# 範例：sentinel://:difyai123456@localhost:26379/1;sentinel://:difyai12345@localhost:26379/1;sentinel://:difyai12345@localhost:26379/1
CELERY_BROKER_URL=redis://:%25%40z%25dVBRS2f8io@redis:6379/1
CELERY_BACKEND=redis
BROKER_USE_SSL=false

# 若使用 Redis Sentinel 實現高可用性，請設定以下項目。
CELERY_USE_SENTINEL=false
CELERY_SENTINEL_MASTER_NAME=
CELERY_SENTINEL_PASSWORD=
CELERY_SENTINEL_SOCKET_TIMEOUT=0.1
# 例如：{"tasks.add": {"rate_limit": "10/s"}}
CELERY_TASK_ANNOTATIONS=null

# ------------------------------
# CORS 設定
# 用於設定前端跨網域存取政策。
# ------------------------------

# 指定允許對 Web API 進行跨來源請求的來源，
# 例如 https://dify.app，或 * 表示允許所有來源。
WEB_API_CORS_ALLOW_ORIGINS=*

# 指定允許對 Console API 進行跨來源請求的來源，
# 例如 https://cloud.dify.ai，或 * 表示允許所有來源。
CONSOLE_CORS_ALLOW_ORIGINS=*
# 前端與後端在不同子網域時，將 COOKIE_DOMAIN 設為網站的頂級網域（例如 `example.com`）。前置點可省略。
COOKIE_DOMAIN=
# 前端與後端在不同子網域時，設定 NEXT_PUBLIC_COOKIE_DOMAIN=1。
NEXT_PUBLIC_COOKIE_DOMAIN=
NEXT_PUBLIC_BATCH_CONCURRENCY=5

# ------------------------------
# 檔案儲存設定
# ------------------------------

# 用於儲存使用者檔案的儲存類型。
STORAGE_TYPE=opendal

# Apache OpenDAL 設定
# OpenDAL 的設定格式為：OPENDAL_<SCHEME_NAME>_<CONFIG_NAME>。
# 可在以下位置找到所有服務設定（CONFIG_NAME）：https://github.com/apache/opendal/tree/main/core/src/services
# Dify 將掃描以 OPENDAL_<SCHEME_NAME> 開頭的設定並自動套用。
# OpenDAL 儲存的 scheme 名稱。
OPENDAL_SCHEME=fs
# OpenDAL 本機檔案系統設定。
OPENDAL_FS_ROOT=storage

# ClickZetta Volume 設定（用於儲存後端）
# 若要使用 ClickZetta Volume 作為儲存後端，設定 STORAGE_TYPE=clickzetta-volume
# 注意：ClickZetta Volume 將重用現有的 CLICKZETTA_* 連線參數

# Volume 類型選擇（共三種）：
# - user：個人或小型團隊使用，設定簡單，使用者層級權限
# - table：企業多租戶，智慧路由，資料表層級 + 使用者層級權限
# - external：資料湖整合，外部儲存連接，volume 層級 + 儲存層級權限
CLICKZETTA_VOLUME_TYPE=user

# External Volume 名稱（僅在 TYPE=external 時必填）
CLICKZETTA_VOLUME_NAME=

# Table Volume 資料表前綴（僅在 TYPE=table 時使用）
CLICKZETTA_VOLUME_TABLE_PREFIX=dataset_

# Dify 檔案目錄前綴（與其他應用隔離，建議保留預設值）
CLICKZETTA_VOLUME_DIFY_PREFIX=dify_km

# S3 設定
#
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET_NAME=difyai
S3_ACCESS_KEY=
S3_SECRET_KEY=
# 是否使用 AWS 受管 IAM 角色向 S3 服務驗證身份。
# 若設為 false，則必須提供 access key 和 secret key。
S3_USE_AWS_MANAGED_IAM=false

# 工作流程執行與對話封存儲存（S3 相容）
ARCHIVE_STORAGE_ENABLED=false
ARCHIVE_STORAGE_ENDPOINT=
ARCHIVE_STORAGE_ARCHIVE_BUCKET=
ARCHIVE_STORAGE_EXPORT_BUCKET=
ARCHIVE_STORAGE_ACCESS_KEY=
ARCHIVE_STORAGE_SECRET_KEY=
ARCHIVE_STORAGE_REGION=auto

# Azure Blob 設定
#
AZURE_BLOB_ACCOUNT_NAME=difyai
AZURE_BLOB_ACCOUNT_KEY=difyai
AZURE_BLOB_CONTAINER_NAME=difyai-container
AZURE_BLOB_ACCOUNT_URL=https://<your_account_name>.blob.core.windows.net

# Google 儲存設定
#
GOOGLE_STORAGE_BUCKET_NAME=your-bucket-name
GOOGLE_STORAGE_SERVICE_ACCOUNT_JSON_BASE64=

# 阿里雲 OSS 設定，
#
ALIYUN_OSS_BUCKET_NAME=your-bucket-name
ALIYUN_OSS_ACCESS_KEY=your-access-key
ALIYUN_OSS_SECRET_KEY=your-secret-key
ALIYUN_OSS_ENDPOINT=https://oss-ap-southeast-1-internal.aliyuncs.com
ALIYUN_OSS_REGION=ap-southeast-1
ALIYUN_OSS_AUTH_VERSION=v4
# 不要以 '/' 開頭，OSS 不支援物件名稱以斜線開頭。
