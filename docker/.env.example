# ------------------------------
# 向量資料庫設定
# ------------------------------

# 要使用的向量資料庫類型。
# 支援的值為 `weaviate`、`oceanbase`、`seekdb`、`qdrant`、`milvus`、`myscale`、`relyt`、`pgvector`、`pgvecto-rs`、`chroma`、`opensearch`、`oracle`、`tencent`、`elasticsearch`、`elasticsearch-ja`、`analyticdb`、`couchbase`、`vikingdb`、`opengauss`、`tablestore`、`vastbase`、`tidb`、`tidb_on_qdrant`、`baidu`、`lindorm`、`huawei_cloud`、`upstash`、`matrixone`、`clickzetta`、`alibabacloud_mysql`、`iris`、`hologres`。
VECTOR_STORE=weaviate
# 用於在向量資料庫中建立 collection 名稱的前綴
VECTOR_INDEX_NAME_PREFIX=Vector_index

# Weaviate 端點 URL，僅在 VECTOR_STORE 為 `weaviate` 時有效。
WEAVIATE_ENDPOINT=http://weaviate:8080
WEAVIATE_API_KEY=WVF5YThaHlkYwhGUSmCRgsX3tD5ngdN8pkih
WEAVIATE_GRPC_ENDPOINT=grpc://weaviate:50051
WEAVIATE_TOKENIZATION=word

# OceanBase 元數據資料庫設定，當 `DB_TYPE` 為 `oceanbase` 時可用。
# OceanBase 向量資料庫設定，當 `VECTOR_STORE` 為 `oceanbase` 時可用
# 若要同時使用 OceanBase 作為向量資料庫和元數據資料庫，需將 `DB_TYPE` 和 `VECTOR_STORE` 均設為 `oceanbase`，且資料庫設定需與向量資料庫相同。
# seekdb 是 OceanBase 的精簡版，共用 OceanBase 的連線設定。
OCEANBASE_VECTOR_HOST=oceanbase
OCEANBASE_VECTOR_PORT=2881
OCEANBASE_VECTOR_USER=root@test
OCEANBASE_VECTOR_PASSWORD=difyai123456
OCEANBASE_VECTOR_DATABASE=test
OCEANBASE_CLUSTER_NAME=difyai
OCEANBASE_MEMORY_LIMIT=6G
OCEANBASE_ENABLE_HYBRID_SEARCH=false
# OceanBase 向量資料庫的內建全文解析器為 `ngram`、`beng`、`space`、`ngram2`、`ik`
# OceanBase 向量資料庫的外部全文解析器（需安裝外掛程式）為 `japanese_ftparser`、`thai_ftparser`
OCEANBASE_FULLTEXT_PARSER=ik
SEEKDB_MEMORY_LIMIT=2G

