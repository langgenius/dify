# Worker 的逾時時間（秒）
SANDBOX_WORKER_TIMEOUT=15
# 啟用 Sandbox 服務的網路
SANDBOX_ENABLE_NETWORK=true
# 用於 SSRF 保護的 HTTP Proxy URL
