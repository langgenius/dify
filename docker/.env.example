IRIS_MIN_CONNECTION=1
IRIS_MAX_CONNECTION=3
IRIS_TEXT_INDEX=true
IRIS_TEXT_INDEX_LANGUAGE=en
IRIS_TIMEZONE=UTC

# ------------------------------
# 知識庫設定
# ------------------------------

# 上傳檔案大小限制，預設 15M。
UPLOAD_FILE_SIZE_LIMIT=15

# 單次可上傳的最大檔案數量，預設 5。
UPLOAD_FILE_BATCH_LIMIT=5

# 基於安全考量，以逗號分隔的禁止上傳副檔名清單。
# 副檔名應為小寫且不含點（例如 exe,bat,sh,dll）。
# 預設為空，允許所有檔案類型。
# 建議：exe,bat,cmd,com,scr,vbs,ps1,msi,dll
UPLOAD_FILE_EXTENSION_BLACKLIST=

# 單次附件允許的最大檔案數量，預設 10。
SINGLE_CHUNK_ATTACHMENT_LIMIT=10

# 圖片批次上傳作業允許的最大檔案數量
IMAGE_FILE_BATCH_LIMIT=10

# 附件允許的最大圖片檔案大小（MB），預設 2。
ATTACHMENT_IMAGE_FILE_SIZE_LIMIT=2

# 下載圖片附件的逾時時間（秒），預設 60。
ATTACHMENT_IMAGE_DOWNLOAD_TIMEOUT=60


# ETL 類型，支援：`dify`、`Unstructured`
# `dify`：Dify 的專有檔案提取方案
# `Unstructured`：Unstructured.io 檔案提取方案
ETL_TYPE=dify

# Unstructured API 路徑和 API 金鑰，當 ETL_TYPE 為 Unstructured 時需設定
# 或在 pptx 文件提取節點使用 Unstructured。
# 例如：http://unstructured:8000/general/v0/general
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=
SCARF_NO_ANALYTICS=true

# ------------------------------
# 模型設定
# ------------------------------

# 提示詞生成允許的最大 token 數量。
# 此設定控制程式碼生成工具中 LLM 可使用的 token 上限。
# 於提示詞生成工具中生成提示詞時。
# 預設：512 tokens。
PROMPT_GENERATION_MAX_TOKENS=512

# 程式碼生成允許的最大 token 數量。
# 此設定控制程式碼生成工具中 LLM 可使用的 token 上限。
# 於程式碼生成工具中生成程式碼時。
# 預設：1024 tokens。
CODE_GENERATION_MAX_TOKENS=1024

# 啟用或停用基於外掛程式的 token 計數。停用後，token 計數將回傳 0。
# 跳過 token 計數作業可改善效能。
# 預設：false（停用）。
PLUGIN_BASED_TOKEN_COUNTING_ENABLED=false

# ------------------------------
# 多模態設定
# ------------------------------

# 多模態模型輸入時發送圖片/影片/音訊/文件的格式，
# 預設為 base64，可選 url。
# url 模式的呼叫延遲低於 base64 模式。
# 一般建議使用相容性更好的 base64 模式。
# 若設為 url，需將 FILES_URL 設定為外部可存取的地址，以便多模態模型存取圖片/影片/音訊/文件。
MULTIMODAL_SEND_FORMAT=base64
# 上傳圖片檔案大小限制，預設 10M。
UPLOAD_IMAGE_FILE_SIZE_LIMIT=10
# 上傳影片檔案大小限制，預設 100M。
UPLOAD_VIDEO_FILE_SIZE_LIMIT=100
# 上傳音訊檔案大小限制，預設 50M。
UPLOAD_AUDIO_FILE_SIZE_LIMIT=50

# ------------------------------
# Sentry 設定
# 用於應用程式監控和錯誤日誌追蹤。
# ------------------------------
SENTRY_DSN=

# API 服務 Sentry DSN 地址，預設為空，
# 所有監控資訊不會回報至 Sentry。
# 若未設定，Sentry 錯誤回報將停用。
API_SENTRY_DSN=
# API 服務 Sentry 事件的回報比例，0.01 表示 1%。
API_SENTRY_TRACES_SAMPLE_RATE=1.0
# API 服務 Sentry profiles 的回報比例，0.01 表示 1%。
API_SENTRY_PROFILES_SAMPLE_RATE=1.0

# Web 服務 Sentry DSN 地址，預設為空，
# 所有監控資訊不會回報至 Sentry。
# 若未設定，Sentry 錯誤回報將停用。
WEB_SENTRY_DSN=

# Plugin Daemon 服務 Sentry DSN 地址，預設為空，
# 所有監控資訊不會回報至 Sentry。
# 若未設定，Sentry 錯誤回報將停用。
PLUGIN_SENTRY_ENABLED=false
PLUGIN_SENTRY_DSN=

# ------------------------------
# Notion 整合設定
# 可透過申請 Notion 整合取得相關變數：https://www.notion.so/my-integrations
# ------------------------------

# 設定為 "public" 或 "internal"。
# 由於 Notion 的 OAuth 重導向 URL 僅支援 HTTPS，
# 若在本機部署，請使用 Notion 的 internal 整合。
NOTION_INTEGRATION_TYPE=public
# Notion OAuth 用戶端密鑰（用於 public 整合類型）
NOTION_CLIENT_SECRET=
# Notion OAuth 用戶端 ID（用於 public 整合類型）
NOTION_CLIENT_ID=
# Notion internal 整合密鑰。
# 若 NOTION_INTEGRATION_TYPE 的值為 "internal"，
# 需要設定此變數。
NOTION_INTERNAL_SECRET=

# ------------------------------
# 郵件相關設定
# ------------------------------

# 郵件類型，支援：resend、smtp、sendgrid
MAIL_TYPE=resend

# 預設寄件人電子郵件地址，若未指定
# 若使用 SendGrid，必要時使用 'from' 欄位進行驗證。
MAIL_DEFAULT_SEND_FROM=

# Resend 郵件服務的 API 金鑰，當 MAIL_TYPE 為 `resend` 時使用。
RESEND_API_URL=https://api.resend.com
RESEND_API_KEY=your-resend-api-key


# SMTP 伺服器設定，當 MAIL_TYPE 為 `smtp` 時使用
SMTP_SERVER=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_OPPORTUNISTIC_TLS=false
# 選填：覆寫 SMTP HELO/EHLO 使用的本機主機名稱
SMTP_LOCAL_HOSTNAME=

# SendGrid 設定
SENDGRID_API_KEY=

# ------------------------------
# 其他設定
# ------------------------------

# 索引的最大分段 token 長度
INDEXING_MAX_SEGMENTATION_TOKENS_LENGTH=4000

# 成員邀請連結有效時間（小時），
# 預設：72。
INVITE_EXPIRY_HOURS=72

# 重設密碼 token 有效時間（分鐘），
RESET_PASSWORD_TOKEN_EXPIRY_MINUTES=5
EMAIL_REGISTER_TOKEN_EXPIRY_MINUTES=5
CHANGE_EMAIL_TOKEN_EXPIRY_MINUTES=5
OWNER_TRANSFER_TOKEN_EXPIRY_MINUTES=5

# Sandbox 服務端點。
CODE_EXECUTION_ENDPOINT=http://sandbox:8194
CODE_EXECUTION_API_KEY=dify-sandbox
CODE_EXECUTION_SSL_VERIFY=True
CODE_EXECUTION_POOL_MAX_CONNECTIONS=100
CODE_EXECUTION_POOL_MAX_KEEPALIVE_CONNECTIONS=20
CODE_EXECUTION_POOL_KEEPALIVE_EXPIRY=5.0
CODE_MAX_NUMBER=9223372036854775807
CODE_MIN_NUMBER=-9223372036854775808
CODE_MAX_DEPTH=5
CODE_MAX_PRECISION=20
CODE_MAX_STRING_LENGTH=400000
CODE_MAX_STRING_ARRAY_LENGTH=30
CODE_MAX_OBJECT_ARRAY_LENGTH=30
CODE_MAX_NUMBER_ARRAY_LENGTH=1000
CODE_EXECUTION_CONNECT_TIMEOUT=10
CODE_EXECUTION_READ_TIMEOUT=60
CODE_EXECUTION_WRITE_TIMEOUT=10
TEMPLATE_TRANSFORM_MAX_LENGTH=400000

# 工作流程執行時設定
WORKFLOW_MAX_EXECUTION_STEPS=500
WORKFLOW_MAX_EXECUTION_TIME=1200
WORKFLOW_CALL_MAX_DEPTH=5
MAX_VARIABLE_SIZE=204800
WORKFLOW_FILE_UPLOAD_LIMIT=10

# GraphEngine Worker Pool 設定
# 每個 GraphEngine 實例的最小 Worker 數量（預設：1）
GRAPH_ENGINE_MIN_WORKERS=1
# 每個 GraphEngine 實例的最大 Worker 數量（預設：10）
GRAPH_ENGINE_MAX_WORKERS=10
# 觸發 Worker 擴容的佇列深度門檻（預設：3）
GRAPH_ENGINE_SCALE_UP_THRESHOLD=3
# Worker 縮容前的閒置秒數（預設：5.0）
GRAPH_ENGINE_SCALE_DOWN_IDLE_TIME=5.0

# 工作流程儲存設定
# 選項：rdbms、hybrid
# rdbms：僅使用關聯式資料庫（預設）
# hybrid：將新資料儲存至物件儲存，從物件儲存和 RDBMS 兩者讀取
WORKFLOW_NODE_EXECUTION_STORAGE=rdbms

# Repository 設定
# 核心工作流程執行 Repository 實作
# 選項：
#   - core.repositories.sqlalchemy_workflow_execution_repository.SQLAlchemyWorkflowExecutionRepository（預設）
#   - core.repositories.celery_workflow_execution_repository.CeleryWorkflowExecutionRepository
#   - extensions.logstore.repositories.logstore_workflow_execution_repository.LogstoreWorkflowExecutionRepository
CORE_WORKFLOW_EXECUTION_REPOSITORY=core.repositories.sqlalchemy_workflow_execution_repository.SQLAlchemyWorkflowExecutionRepository

# 核心工作流程節點執行 Repository 實作
# 選項：
#   - core.repositories.sqlalchemy_workflow_node_execution_repository.SQLAlchemyWorkflowNodeExecutionRepository（預設）
#   - core.repositories.celery_workflow_node_execution_repository.CeleryWorkflowNodeExecutionRepository
#   - extensions.logstore.repositories.logstore_workflow_node_execution_repository.LogstoreWorkflowNodeExecutionRepository
CORE_WORKFLOW_NODE_EXECUTION_REPOSITORY=core.repositories.sqlalchemy_workflow_node_execution_repository.SQLAlchemyWorkflowNodeExecutionRepository

# API 工作流程執行 Repository 實作
# 選項：
#   - repositories.sqlalchemy_api_workflow_run_repository.DifyAPISQLAlchemyWorkflowRunRepository（預設）
#   - extensions.logstore.repositories.logstore_api_workflow_run_repository.LogstoreAPIWorkflowRunRepository
API_WORKFLOW_RUN_REPOSITORY=repositories.sqlalchemy_api_workflow_run_repository.DifyAPISQLAlchemyWorkflowRunRepository

# API 工作流程節點執行 Repository 實作
# 選項：
#   - repositories.sqlalchemy_api_workflow_node_execution_repository.DifyAPISQLAlchemyWorkflowNodeExecutionRepository（預設）
#   - extensions.logstore.repositories.logstore_api_workflow_node_execution_repository.LogstoreAPIWorkflowNodeExecutionRepository
API_WORKFLOW_NODE_EXECUTION_REPOSITORY=repositories.sqlalchemy_api_workflow_node_execution_repository.DifyAPISQLAlchemyWorkflowNodeExecutionRepository

# 工作流程日誌清理設定
# 啟用自動清理工作流程執行日誌以管理資料庫大小
WORKFLOW_LOG_CLEANUP_ENABLED=false
# 工作流程執行日誌的保留天數（預設：30 天）
WORKFLOW_LOG_RETENTION_DAYS=30
# 工作流程日誌清理作業的批次大小（預設：100）
WORKFLOW_LOG_CLEANUP_BATCH_SIZE=100
# 以逗號分隔的工作流程 ID 清單，用於清理指定工作流程的日誌
WORKFLOW_LOG_CLEANUP_SPECIFIC_WORKFLOW_IDS=

# 阿里雲 SLS Logstore 設定
# 阿里雲 Access Key ID
ALIYUN_SLS_ACCESS_KEY_ID=
# 阿里雲 Access Key Secret
ALIYUN_SLS_ACCESS_KEY_SECRET=
# 阿里雲 SLS Endpoint（例如 cn-hangzhou.log.aliyuncs.com）
ALIYUN_SLS_ENDPOINT=
# 阿里雲 SLS Region（例如 cn-hangzhou）
ALIYUN_SLS_REGION=
# 阿里雲 SLS 專案名稱
ALIYUN_SLS_PROJECT_NAME=
# 工作流程執行日誌的保留天數（預設：365 天，3650 為永久儲存）
ALIYUN_SLS_LOGSTORE_TTL=365
# 啟用同時寫入 SLS LogStore 和 SQL 資料庫（預設：false）
LOGSTORE_DUAL_WRITE_ENABLED=false
# 當 LogStore 無回傳結果時啟用回退至 SQL 資料庫讀取（預設：true）
# 適用於歷史資料僅存在於 SQL 資料庫的遷移場景
LOGSTORE_DUAL_READ_ENABLED=true
# 控制是否將 `graph` 欄位寫入 LogStore 的旗標。
# 若 LOGSTORE_ENABLE_PUT_GRAPH_FIELD 為 "true"，則寫入完整 `graph` 欄位；
# 否則寫入空的 {} 代替。預設寫入 `graph` 欄位。
LOGSTORE_ENABLE_PUT_GRAPH_FIELD=true

# 工作流程中 HTTP 請求節點設定
HTTP_REQUEST_NODE_MAX_BINARY_SIZE=10485760
HTTP_REQUEST_NODE_MAX_TEXT_SIZE=1048576
HTTP_REQUEST_NODE_SSL_VERIFY=True

# HTTP 請求節點逾時設定
# 使用者可在 HTTP 請求節點設定的最大逾時值（秒）
# - 連線逾時：等待建立連線的時間（預設：10 秒）
# - 讀取逾時：等待接收回應資料的時間（預設：600 秒，10 分鐘）
# - 寫入逾時：等待發送請求資料的時間（預設：600 秒，10 分鐘）
HTTP_REQUEST_MAX_CONNECT_TIMEOUT=10
HTTP_REQUEST_MAX_READ_TIMEOUT=600
HTTP_REQUEST_MAX_WRITE_TIMEOUT=600

# 自訂憑證驗證的 Base64 編碼 CA 憑證資料（PEM 格式，選填）
# HTTP_REQUEST_NODE_SSL_CERT_DATA=LS0tLS1CRUdJTi...
# 雙向 TLS 驗證的 Base64 編碼用戶端憑證資料（PEM 格式，選填）
# HTTP_REQUEST_NODE_SSL_CLIENT_CERT_DATA=LS0tLS1CRUdJTi...
# 雙向 TLS 驗證的 Base64 編碼用戶端私鑰資料（PEM 格式，選填）
# HTTP_REQUEST_NODE_SSL_CLIENT_KEY_DATA=LS0tLS1CRUdJTi...

# Webhook 請求設定
WEBHOOK_REQUEST_BODY_MAX_SIZE=10485760

# 遵守 X-* headers 以重導向用戶端
RESPECT_XFORWARD_HEADERS_ENABLED=false

# SSRF Proxy 伺服器 HTTP URL
SSRF_PROXY_HTTP_URL=http://ssrf_proxy:3128
# SSRF Proxy 伺服器 HTTPS URL
SSRF_PROXY_HTTPS_URL=http://ssrf_proxy:3128

# 工作流程中的最大迴圈次數
LOOP_NODE_MAX_COUNT=100

# Agent 可使用的最大工具數量。
MAX_TOOLS_NUM=10

# 工作流程中的最大平行分支數量
MAX_PARALLEL_LIMIT=10

# Agent 設定的最大迭代次數
MAX_ITERATIONS_NUM=99

# ------------------------------
# Web 服務的環境變數
# ------------------------------

# 文字生成的逾時時間（毫秒）
TEXT_GENERATION_TIMEOUT_MS=60000

# 允許渲染具有 "data:" scheme 的不安全 URL。
ALLOW_UNSAFE_DATA_SCHEME=false

# 工作流程中樹的最大深度
MAX_TREE_DEPTH=50

# ------------------------------
# 資料庫服務的環境變數
# ------------------------------
# PostgreSQL 資料目錄
PGDATA=/var/lib/postgresql/data/pgdata

# MySQL 預設設定
MYSQL_HOST_VOLUME=./volumes/mysql/data

# ------------------------------
