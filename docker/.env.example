# ------------------------------
# OpenSearch 的環境變數
# （僅在 VECTOR_STORE 為 opensearch 時使用）
# ------------------------------
OPENSEARCH_DISCOVERY_TYPE=single-node
OPENSEARCH_BOOTSTRAP_MEMORY_LOCK=true
OPENSEARCH_JAVA_OPTS_MIN=512m
OPENSEARCH_JAVA_OPTS_MAX=1024m
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Qazwsxedc!@#123
OPENSEARCH_MEMLOCK_SOFT=-1
OPENSEARCH_MEMLOCK_HARD=-1
OPENSEARCH_NOFILE_SOFT=65536
OPENSEARCH_NOFILE_HARD=65536

# ------------------------------
# Nginx 反向代理的環境變數
# ------------------------------
NGINX_SERVER_NAME=_
NGINX_HTTPS_ENABLED=false
# HTTP 埠
NGINX_PORT=80
# SSL 設定僅在 HTTPS_ENABLED 為 true 時套用
NGINX_SSL_PORT=443
# 若 HTTPS_ENABLED 為 true，需將自己的 SSL 憑證/金鑰加入 `./nginx/ssl` 目錄
# 並相應修改下方的環境變數。
NGINX_SSL_CERT_FILENAME=dify.crt
NGINX_SSL_CERT_KEY_FILENAME=dify.key
NGINX_SSL_PROTOCOLS=TLSv1.2 TLSv1.3

# Nginx 效能調校
NGINX_WORKER_PROCESSES=auto
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_KEEPALIVE_TIMEOUT=65

# Proxy 設定
NGINX_PROXY_READ_TIMEOUT=3600s
NGINX_PROXY_SEND_TIMEOUT=3600s

# 設為 true 以接受 /.well-known/acme-challenge/ 的請求
NGINX_ENABLE_CERTBOT_CHALLENGE=false

# ------------------------------
# Certbot 設定
# ------------------------------

# 電子郵件地址（從 Let's Encrypt 取得憑證時必填）
CERTBOT_EMAIL=your_email@example.com

# 網域名稱
CERTBOT_DOMAIN=your_domain.com

# certbot 指令選項
# 例如：--force-renewal --dry-run --test-cert --debug
CERTBOT_OPTIONS=

# ------------------------------
# SSRF Proxy 的環境變數
# ------------------------------
SSRF_HTTP_PORT=3128
SSRF_COREDUMP_DIR=/var/spool/squid
SSRF_REVERSE_PROXY_PORT=8194
SSRF_SANDBOX_HOST=sandbox
SSRF_DEFAULT_TIME_OUT=5
SSRF_DEFAULT_CONNECT_TIME_OUT=5
SSRF_DEFAULT_READ_TIME_OUT=5
SSRF_DEFAULT_WRITE_TIME_OUT=5
SSRF_POOL_MAX_CONNECTIONS=100
SSRF_POOL_MAX_KEEPALIVE_CONNECTIONS=20
SSRF_POOL_KEEPALIVE_EXPIRY=5.0

# ------------------------------
# 指定啟動時向量資料庫和元數據資料庫類型的 Docker 環境變數
# （根據向量資料庫和元數據資料庫類型，將使用對應的 Docker
