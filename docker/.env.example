DSL_EXPORT_ENCRYPT_DATASET_ID=true

# 資料集分段 API 的最大分段數量（0 為無限制）
DATASET_MAX_SEGMENTS_PER_REQUEST=0

# Celery 排程任務設定
ENABLE_CLEAN_EMBEDDING_CACHE_TASK=false
ENABLE_CLEAN_UNUSED_DATASETS_TASK=false
ENABLE_CREATE_TIDB_SERVERLESS_TASK=false
ENABLE_UPDATE_TIDB_SERVERLESS_STATUS_TASK=false
ENABLE_CLEAN_MESSAGES=false
ENABLE_WORKFLOW_RUN_CLEANUP_TASK=false
ENABLE_MAIL_CLEAN_DOCUMENT_NOTIFY_TASK=false
ENABLE_DATASETS_QUEUE_MONITOR=false
ENABLE_CHECK_UPGRADABLE_PLUGIN_TASK=true
ENABLE_WORKFLOW_SCHEDULE_POLLER_TASK=true
WORKFLOW_SCHEDULE_POLLER_INTERVAL=1
WORKFLOW_SCHEDULE_POLLER_BATCH_SIZE=100
WORKFLOW_SCHEDULE_MAX_DISPATCH_PER_TICK=0

# 租戶隔離任務佇列設定
TENANT_ISOLATED_TASK_CONCURRENCY=1

# 標註匯入允許的最大 CSV 檔案大小（MB）
ANNOTATION_IMPORT_FILE_SIZE_LIMIT=2
# 單次匯入允許的最大標註記錄數
ANNOTATION_IMPORT_MAX_RECORDS=10000
# 單次匯入所需的最小標註記錄數
ANNOTATION_IMPORT_MIN_RECORDS=1
ANNOTATION_IMPORT_RATE_LIMIT_PER_MINUTE=5
ANNOTATION_IMPORT_RATE_LIMIT_PER_HOUR=20
# 每個租戶的最大並發標註匯入任務數
ANNOTATION_IMPORT_MAX_CONCURRENT=5

# Amplitude 的 API 金鑰
AMPLITUDE_API_KEY=

# Sandbox 過期記錄清理設定
SANDBOX_EXPIRED_RECORDS_CLEAN_GRACEFUL_PERIOD=21
SANDBOX_EXPIRED_RECORDS_CLEAN_BATCH_SIZE=1000
SANDBOX_EXPIRED_RECORDS_CLEAN_BATCH_MAX_INTERVAL=200
SANDBOX_EXPIRED_RECORDS_RETENTION_DAYS=30


# API 與 Celery Worker 之間事件匯流排使用的 Redis URL
# Celery Worker
# 預設為由 `REDIS_*` 設定建構的 URL
# 設定
EVENT_BUS_REDIS_URL=
# 事件傳輸類型。選項為：
#
#  - pubsub：一般 Pub/Sub（至多一次）
#  - sharded：分片 Pub/Sub（至多一次）
#  - streams：Redis Streams（至少一次，建議使用以避免訂閱者競爭）
#
# 注意：在正式環境啟用 'streams' 前，請評估預期的事件量和保留需求。
# 適當設定 Redis 記憶體限制和串流修剪（例如 MAXLEN 和金鑰過期），以降低
# 記憶體壓力下 Redis 自動驅逐造成資料遺失的風險。
# 也接受環境變數：EVENT_BUS_REDIS_CHANNEL_TYPE。
EVENT_BUS_REDIS_CHANNEL_TYPE=pubsub
# 使用 Redis 作為事件匯流排時，是否使用 Redis Cluster 模式。
#  強烈建議大型部署時啟用此設定。
EVENT_BUS_REDIS_USE_CLUSTERS=false

# 是否啟用人工輸入逾時檢查任務
ENABLE_HUMAN_INPUT_TIMEOUT_TASK=true
# 人工輸入逾時檢查間隔（分鐘）
HUMAN_INPUT_TIMEOUT_TASK_INTERVAL=1


SANDBOX_EXPIRED_RECORDS_CLEAN_TASK_LOCK_TTL=90000
