# .env.staging
# Staging Environment Configuration

# 应用配置
LOG_LEVEL=INFO
DEBUG=false
ENVIRONMENT=staging

# 数据库
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=dify-staging
DATABASE_USER=postgres
DATABASE_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# API 配置
API_HOST=0.0.0.0
API_PORT=5001

# 前端配置
NEXT_PUBLIC_API_URL=http://api.staging.dify.example.com
NEXT_PUBLIC_APP_URL=http://staging.dify.example.com

# JWT
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRATION=7d

# 邮件配置
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=Dify Staging <noreply@example.com>

# LLM 提供商
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# 其他服务
STRIPE_API_KEY=your-staging-stripe-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# S3 / 对象存储
STORAGE_TYPE=local  # 或 s3
S3_BUCKET=dify-staging
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
