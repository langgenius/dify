# Dify secret key - generate with: openssl rand -base64 42
SECRET_KEY=your-secret-key-here

# Public-facing URL of your server (used in invitation emails and links)
CONSOLE_WEB_URL=http://your-server-ip
APP_WEB_URL=http://your-server-ip

# Postgres
DB_USERNAME=postgres
DB_PASSWORD=difyai123456
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dify

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=difyai123456

# Storage
STORAGE_TYPE=local

# Vector store
VECTOR_STORE=pgvector
PGVECTOR_HOST=db
PGVECTOR_PORT=5432
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=difyai123456
PGVECTOR_DATABASE=dify

# Sandbox (required for Code nodes in workflows)
SANDBOX_API_KEY=dify-sandbox

# Plugin daemon
PLUGIN_DAEMON_URL=http://plugin_daemon:5002
PLUGIN_DAEMON_KEY=lYkiYYT6owG+71oLerGzA7GXCgOT++6ovaezWAjpCjf+Sjc3ZtU+qUEi

# Celery broker - must point to Redis, not default RabbitMQ
CELERY_BROKER_URL=redis://:<REDIS_PASSWORD>@redis:6379/1
BROKER_USE_SSL=false

# SMTP (AWS SES) - delete from .env after team invites are sent
MAIL_TYPE=smtp
MAIL_DEFAULT_SEND_FROM=your-email@yourdomain.com
SMTP_SERVER=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=465
SMTP_USERNAME=your-ses-smtp-username
SMTP_PASSWORD=your-ses-smtp-password
SMTP_USE_TLS=true
