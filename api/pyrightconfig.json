    "dify_vdb_elasticsearch",
    "dify_vdb_hologres",
    "dify_vdb_huawei_cloud",
    "dify_vdb_iris",
    "dify_vdb_lindorm",
    "dify_vdb_matrixone",
    "dify_vdb_milvus",
    "dify_vdb_myscale",
    "dify_vdb_oceanbase",
    "dify_vdb_opengauss",
    "dify_vdb_opensearch",
    "dify_vdb_oracle",
    "dify_vdb_pgvecto_rs",
    "dify_vdb_pgvector",
    "dify_vdb_relyt",
    "dify_vdb_tablestore",
