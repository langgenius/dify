{
  "extends": "@dify/tsconfig/nextjs.json",
  "compilerOptions": {
    "incremental": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "~@/*": [
        "./*"
      ],
      "@dify/studio-frontend/*": [
        "../packages/studio-frontend/src/*"
      ],
      "@/app/components/workflow/*": [
        "../packages/studio-frontend/src/workflow/*"
      ],
      "@/app/components/app/*": [
        "../packages/studio-frontend/src/app/components/*"
      ],
      "@/app/(commonLayout)/apps/*": [
        "../packages/studio-frontend/src/apps/pages/*"
      ],
      "@/app/(commonLayout)/app/(appDetailLayout)/*": [
        "../packages/studio-frontend/src/app/detail/*"
      ],
      "@/app/components/app-sidebar/*": [
        "../packages/studio-frontend/src/app-sidebar/components/*"
      ],
      "@/app/components/workflow-app/*": [
        "../packages/studio-frontend/src/workflow-app/components/*"
      ],
      "@/app/components/develop/*": [
        "../packages/studio-frontend/src/develop/components/*"
      ],
      "@dify/studio-frontend/contracts/*": [
        "../packages/studio-frontend/src/contracts/*"
      ],
      "@dify/studio-frontend/types/*": [
        "../packages/studio-frontend/src/types/*"
      ],
      "@dify/studio-frontend/utils/*": [
        "../packages/studio-frontend/src/utils/*"
      ],
      "@dify/studio-frontend/components/*": [
        "../packages/studio-frontend/src/components/*"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "vitest/globals",
      "node"
    ],
    "allowImportingTsExtensions": true,
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
